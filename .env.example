# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Default model
AXELO_MODEL=claude-opus-4-6

# Workspace directory
AXELO_WORKSPACE=./workspace

# Node.js executable
AXELO_NODE_BIN=node

# Browser engine (chromium/firefox/webkit)
AXELO_BROWSER=chromium

# Run browser headless
AXELO_HEADLESS=true

# Log level (debug/info/warning/error)
AXELO_LOG_LEVEL=info

# Dynamic-analysis retries after operator-approved retry requests
AXELO_MAX_DYNAMIC_RETRIES=2

# Verification subprocess timeout in seconds
AXELO_VERIFICATION_SUBPROCESS_TIMEOUT_SEC=15

# Hard cap for a single downloaded bundle in KB
AXELO_BUNDLE_DOWNLOAD_BYTE_CAP_KB=1024

# Platform mode: local/cluster
AXELO_PLATFORM_MODE=local

# Optional metadata database URL (defaults to sqlite under workspace/platform)
AXELO_PLATFORM_DATABASE_URL=

# Platform environment and region labels
AXELO_PLATFORM_ENVIRONMENT=dev
AXELO_PLATFORM_REGION=global

# Control API bind address
AXELO_CONTROL_API_HOST=127.0.0.1
AXELO_CONTROL_API_PORT=8787

# Worker / scheduler empty-poll interval
AXELO_PLATFORM_POLL_INTERVAL_SEC=1.0
