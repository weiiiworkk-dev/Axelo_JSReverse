# ============================================================
# Axelo JSReverse — 环境变量示例（DeepSeek Only）
# 复制为 .env 并填入真实值
# ============================================================

# DeepSeek API Key（必填）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# 使用的模型（可选，默认 deepseek-v3）
# deepseek-v3  → deepseek-chat（推荐，速度快）
# deepseek-r1  → deepseek-reasoner（推理任务）
AXELO_MODEL=deepseek-v3

# ── 路径 ──────────────────────────────────────────────────────
# 工作目录（Railway 部署时挂载 Volume 到此路径）
AXELO_WORKSPACE=./workspace

# Node.js 可执行路径（容器内一般为 /usr/bin/node）
AXELO_NODE_BIN=node

# ── 浏览器 ────────────────────────────────────────────────────
# 浏览器引擎（chromium/firefox/webkit）
AXELO_BROWSER=chromium

# 使用系统 Chrome（本地开发可开启，Docker 容器保持空）
# AXELO_BROWSER_CHANNEL=chrome

# 无头模式（Railway 生产环境必须为 true）
AXELO_HEADLESS=true

# ── 日志 ──────────────────────────────────────────────────────
AXELO_LOG_LEVEL=info

# ── 性能调优 ──────────────────────────────────────────────────
# 单个 bundle 下载上限（KB）
AXELO_BUNDLE_DOWNLOAD_BYTE_CAP_KB=512

# 验证子进程超时（秒）
AXELO_VERIFICATION_SUBPROCESS_TIMEOUT_SEC=30

# AST 提取超时（秒）
AXELO_AST_EXTRACT_TIMEOUT_SEC=45

# 动态分析超时（秒）
AXELO_DYNAMIC_ANALYSIS_TIMEOUT_SEC=180

# ── 平台模式 ──────────────────────────────────────────────────
AXELO_PLATFORM_MODE=local
AXELO_PLATFORM_ENVIRONMENT=prod
AXELO_PLATFORM_REGION=global
