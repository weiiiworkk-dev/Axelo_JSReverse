# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# 默认模型
AXELO_MODEL=claude-opus-4-6

# 工作目录（默认 ./workspace）
AXELO_WORKSPACE=./workspace

# Node.js 可执行路径（默认系统 node）
AXELO_NODE_BIN=node

# 浏览器（chromium/firefox/webkit）
AXELO_BROWSER=chromium

# 是否使用无头模式（true/false）
AXELO_HEADLESS=true

# 日志级别（debug/info/warning/error）
AXELO_LOG_LEVEL=info
